{
  "name": "@ahachat.ai/database",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/adapter-pg": "^6.11.1",
    "@prisma/client": "^6.11.1",
    "@prisma/extension-accelerate": "^2.0.1"
  },
  "devDependencies": {
    "@ahachat.ai/typescript-config": "workspace:*",
    "@faker-js/faker": "^9.9.0",
    "@types/node": "^22.16.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.11.1",
    "ts-node": "^10.9.2"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma migrate dev --create-only",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seeders/index.ts",
    "db:client": "dotenv -e ../../.env -- prisma generate",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "db:setup": "pnpm db:migrate && pnpm db:client && pnpm db:seed"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  }
}

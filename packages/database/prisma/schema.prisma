// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  chatbotMembers   ChatbotMember[]
  accounts         Account[]
  sessions         Session[]
  teamMembers      TeamMember[]
  activityLogs     ActivityLog[]
  assignedContacts Contact[]       @relation("AssignedUser")
  logs             Log[]           @relation("ExecutorUser")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Chatbot {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  name            String
  defaultReply    String?
  targetCountry   String?
  defaultLanguage String      @default("en")
  accountTimezone String
  brandColor      String      @default("#016DFF")
  developmentMode Boolean     @default(false)
  logo            String?
  plan            ChatbotPlan

  activityLogs   ActivityLog[]
  aiAgents       AIAgent[]
  aiAssistants   AIAssistant[]
  aiTriggers     AITrigger[]
  chatbotMembers ChatbotMember[]
  contacts       Contact[]
  fields         Field[]
  flows          Flow[]
  flowVersions   FlowVersion[]
  folders        Folder[]
  googleSheets   IntegrationGoogleSheets[]
  inboxes        Inbox[]
  integrations   Integration[]
  logs           Log[]
  openAIs        IntegrationOpenAI[]
  spreadsheets   Spreadsheet[]
  tags           Tag[]
  teamMembers    TeamMember[]
  teams          Team[]
  whatsapps      IntegrationWhatsapp[]
}

model ChatbotMember {
  id                         String            @id @default(cuid())
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  chatbotId                  String
  userId                     String
  role                       ChatbotMemberRole
  isAdmin                    Boolean
  enableAnalytics            Boolean
  enableFlows                Boolean
  enableContacts             Boolean
  enableOnlyAssignedContacts Boolean
  enableEmailAndPhone        Boolean
  enableBroadcast            Boolean
  enableEcommerce            Boolean

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Team {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  name      String

  chatbot          Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  teamMembers      TeamMember[]
  assignedContacts Contact[]    @relation("AssignedTeam")
}

model TeamMember {
  id        String @id @default(cuid())
  chatbotId String
  teamId    String
  userId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  userId    String
  data      String
  action    String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Log {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  chatbotId    String
  logType      LogType
  action       String
  detail       String
  url          String?
  executorType ExecutorType?
  executorId   String?

  chatbot         Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  executorUser    User?    @relation("ExecutorUser", fields: [executorId], references: [id], map: "user_executorId")
  executorContact Contact? @relation("ExecutorContact", fields: [executorId], references: [id], map: "contact_executorId")
}

enum LogType {
  Error
  Audit
}

enum ExecutorType {
  User
  Contact
}

model Contact {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  avatar       String?
  chatbotId    String
  phoneNumber  String?
  email        String?
  firstName    String?
  lastName     String?
  gender       Gender
  source       String
  assignedType AssignedType?
  assignedId   String?
  lastSeenAt   DateTime?

  chatbot      Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  assignedUser User?   @relation("AssignedUser", fields: [assignedId], references: [id], map: "user_assignedId")
  assignedTeam Team?   @relation("AssignedTeam", fields: [assignedId], references: [id], map: "team_assignedId")
  logs         Log[]   @relation("ExecutorContact")
  tags         Tag[]
}

model Folder {
  id         String     @id @default(cuid())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  name       String
  folderType FolderType
  parentId   String?
  chatbotId  String
  isTrash    Boolean    @default(false)
  paths      String[]   @default([])

  parent   Folder?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("ParentChild")
  chatbot  Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  tags     Tag[]
  fields   Field[]
  flows    Flow[]

  @@index([chatbotId])
  @@index([parentId])
}

model Tag {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  name            String
  folderId        String?
  syncToMessenger Boolean
  chatbotId       String

  chatbot  Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  folder   Folder?   @relation(fields: [folderId], references: [id])
  contacts Contact[]

  @@index([folderId])
}

model Field {
  id              String          @id @default(cuid(2))
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  name            String
  customFieldType CustomFieldType
  description     String?
  folderId        String?
  fieldType       FieldType
  value           String?
  showInInbox     Boolean
  chatbotId       String

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id])
}

model Inbox {
  id        String    @id @default(cuid(2))
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chatbotId String
  inboxType InboxType

  integrationWhatsapps IntegrationWhatsapp[]
  chatbot              Chatbot               @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Integration {
  id              String          @id @default(cuid(2))
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  chatbotId       String
  integrationType IntegrationType

  openAI       IntegrationOpenAI?
  googleSheets IntegrationGoogleSheets?
  chatbot      Chatbot                  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model AIAgent {
  id        String   @id @default(cuid(2))
  chatbotId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  prompt    String?
  messages  Json[]

  chatbot            Chatbot             @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integrationOpenAIs IntegrationOpenAI[]
}

model AIAssistant {
  id            String   @id @default(cuid(2))
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chatbotId     String
  name          String
  prompt        String
  model         String
  aiTriggerIds  String[]
  attachmentIds String[]
  temperature   Float

  chatbot           Chatbot             @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integrationOpenAI IntegrationOpenAI[]
}

model AITrigger {
  id           String   @id @default(cuid(2))
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chatbotId    String
  name         String
  description  String?
  flowId       String?
  questions    Json[]
  finalMessage String?

  chatbot            Chatbot             @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integrationOpenAIs IntegrationOpenAI[]
}

model IntegrationOpenAI {
  id                     String   @id @default(cuid(2))
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  chatbotId              String
  integrationId          String   @unique
  auth                   Json
  automatedResponse      Boolean
  automatedVoiceResponse Boolean  @default(false)
  voice                  String?
  prompt                 String?
  model                  String
  temperature            Float
  maxTokens              Int
  aiAssistantId          String?
  aiAgentId              String?

  chatbot     Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integration Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  aiTriggers  AITrigger[]
  aiAssistant AIAssistant? @relation(fields: [aiAssistantId], references: [id])
  aiAgent     AIAgent?     @relation(fields: [aiAgentId], references: [id])
}

model IntegrationGoogleSheets {
  id            String   @id @default(cuid(2))
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chatbotId     String
  integrationId String   @unique
  auth          Json

  chatbot     Chatbot     @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model IntegrationWhatsapp {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  inboxId   String   @unique
  auth      Json

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  inbox   Inbox   @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Spreadsheet {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  name      String
  url       String

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Flow {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  chatbotId        String
  folderId         String?
  name             String
  active           Boolean  @default(true)
  enableInInbox    Boolean  @default(true)
  currentVersionId String?
  draftVersionId   String?

  chatbot      Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  folder       Folder?       @relation(fields: [folderId], references: [id])
  flowVersions FlowVersion[]
}

model FlowVersion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  flowId    String
  nodes     Json
  edges     Json
  isDraft   Boolean

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  flow    Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

enum CustomFieldType {
  ShortText
  Number
  Date
  DateTime
  Boolean
  LongText
}

enum FieldType {
  AccountField
  CustomField
}

enum FolderType {
  Tag
  Flow
  CustomField
  EmailCampaign
  AutomatedResponse
}

enum ChatbotPlan {
  Free
  Pro
}

enum ChatbotMemberRole {
  Owner
  Agent
}

enum Gender {
  Male
  Female
  Unknown
}

enum AssignedType {
  User
  Team
}

enum IntegrationType {
  ChatWidget
  GoogleSheets
  Instagram
  Messenger
  OpenAI
  Whatsapp
}

enum InboxType {
  ChatWidget
  Instagram
  Messenger
  Whatsapp
}

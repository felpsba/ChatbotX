# ─── ChatbotX API ────────────────────────────────────────────────────────────

# Workspace token — found in ChatbotX Settings → Developer → API Keys
# Used for stdio transport. For SSE, pass via ?workspace_token= query param instead.
CHATBOTX_API_KEY=

# API base URL of your ChatbotX instance (e.g. https://app.chatbotx.io/api)
# The MCP server fetches the OpenAPI spec from {CHATBOTX_API_URL}/public-spec.json
CHATBOTX_API_URL=

# Set to "true" to disable TLS certificate verification.
# Only use in local development with self-signed certificates.
CHATBOTX_ALLOW_SELF_SIGNED_CERT=

# ─── MCP Server (SSE / HTTP transport only) ──────────────────────────────────

# Transport mode: "stdio" | "sse" | "both"
# - stdio: Claude spawns the process directly (recommended for local use)
# - sse:   Run as an HTTP server — clients connect via URL
# - both:  Run stdio and SSE simultaneously
CHATBOTX_MCP_TRANSPORT=sse

# Host the SSE server listens on (use 127.0.0.1 for local, 0.0.0.0 for public)
CHATBOTX_MCP_HOST=127.0.0.1

# Port the SSE server listens on
CHATBOTX_MCP_PORT=3333

# URL path for the SSE endpoint
CHATBOTX_MCP_SSE_PATH=/sse

# URL path for the JSON-RPC messages endpoint
CHATBOTX_MCP_MESSAGES_PATH=/messages

# ─── Server identity (sent to AI clients on connect) ─────────────────────────

# Display name shown to AI clients (e.g. Claude, ChatGPT).
# Defaults to the package name if not set.
CHATBOTX_MCP_SERVER_NAME=ChatbotX MCP Server

# Instructions the AI client reads on connect to understand what this server
# does and when to invoke its tools. Useful for clients like ChatGPT.com that
# require explicit guidance to activate tools.
CHATBOTX_MCP_SERVER_INSTRUCTIONS=This MCP server is connected to the user's live ChatbotX workspace. Whenever the user asks about anything related to their ChatbotX workspace — tags, contacts, conversations, broadcasts, flows, sequences, team members, inboxes, or any workspace data — you MUST use the available MCP tools to fetch real-time data. Do NOT answer from training knowledge or provide ChatbotX product documentation.

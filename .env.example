# ─────────────────────────────────────────────
# App Edition
# ─────────────────────────────────────────────
# community | enterprise | cloud
NEXT_PUBLIC_EDITION=community

# ─────────────────────────────────────────────
# Platform Admin
# ─────────────────────────────────────────────
# Email address that can access /manage (platform admin UI).
# Required when NEXT_PUBLIC_EDITION=community or enterprise.
# PLATFORM_ADMIN_EMAIL=admin@example.com

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# Secret used to sign sessions and tokens.
# Must be a 32-byte base64 string. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=VLu1KcS63DTTnZU3Dh/ykI9Ld26YQXy/1IMJdZf/kHI=

# Public URL of the builder app (used for OAuth redirects and email links).
BETTER_AUTH_URL=http://localhost:3123

# ─────────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────────
# Active 32-byte key (hex, 64 chars) used to encrypt developer-app secrets at rest.
# Generate with: openssl rand -hex 32
# MUST be overridden in production.
ENCRYPTION_KEY=16fca8032c77c99a42197a57bce0cf1275c110ab1385f8eb6942665ed317a973

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://chatbotx:secretkey@localhost:5432/chatbotx?schema=public

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# S3 / Object Storage
# ─────────────────────────────────────────────
S3_ACCESS_KEY_ID=chatbotx
S3_SECRET_ACCESS_KEY=secretkey
S3_BUCKET=chatbotx
S3_REGION=us-west-2
# Custom endpoint for S3-compatible storage (e.g. RustFS, MinIO).
# Leave unset to use AWS S3.
S3_ENDPOINT=http://localhost:9000

# ─────────────────────────────────────────────
# SMTP / Email
# ─────────────────────────────────────────────
# Connection URL: smtp[s]://user:pass@host:port
SMTP_SERVER=smtp://username:password@localhost:1025
SMTP_FROM=no-reply@localhost

# HMAC secret shared between builder and realtime to sign/verify
# short-lived (60s) JWTs sent as `Authorization: Bearer <token>`.
# MUST be overridden in production.
REALTIME_BROADCAST_SECRET=secretkey

# ─────────────────────────────────────────────
# Public URLs (Next.js)
# ─────────────────────────────────────────────
# Canonical public URL of the builder app.
NEXT_PUBLIC_BUILDER_URL=http://localhost:3123

# Optional: override the storage base URL used by the browser.
# Defaults to the S3_ENDPOINT value resolved server-side.
# Useful when the storage service is reachable under a different host locally.
# NEXT_PUBLIC_INTERNAL_STORAGE_URL=http://localhost:9000/chatbotx/

# Optional: override the realtime WebSocket/HTTP URL used by the browser.
# Defaults to NEXT_PUBLIC_BUILDER_URL if unset.
# NEXT_PUBLIC_INTERNAL_WS_URL=http://localhost:1999

# ─────────────────────────────────────────────
# Scheduler & Runtime
# ─────────────────────────────────────────────
# Hex range of sequence-scheduler buckets this instance handles (0-255).
SCHEDULER_BUCKET_RANGE=0-255

# Increase Node.js heap for large workloads.
NODE_OPTIONS="--max_old_space_size=4096"

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# Log verbosity: error | warn | info | debug
LOG_LEVEL=debug

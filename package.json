{
  "name": "ahachat.ai",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "biome format --fix",
    "lint": "biome check . --write",
    "locale:pull": "tolgee pull",
    "locale:push": "tolgee sync --continue-on-warning --remove-unused --patterns './apps/builder/src/**/*.ts?(x)' --backup './.tolgee/backup'",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "clean": "pnpm store prune && pnpm -r exec rm -rf node_modules && pnpm -r exec rm -rf .turbo && pnpm -r exec rm -rf .next"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tolgee/cli": "^2.13.0",
    "@types/node": "^22.16.0",
    "lefthook": "^1.11.16",
    "tsx": "^4.20.3",
    "turbo": "^2.5.5",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "engines": {
    "node": ">=22"
  },
  "workspaces": ["apps/*", "packages/*"]
}

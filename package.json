{
  "name": "ahachat.ai",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "ultracite fix --unsafe",
    "lint": "ultracite lint",
    "clean": "pnpm store prune && pnpm dlx rimraf --glob '**/{node_modules,.next,.turbo}'",
    "imports:check": "pnpm dlx madge --circular --extensions ts,tsx --exclude generated {apps/**/src,packages/**/src}",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/node": "^22.18.12",
    "knip": "^5.66.2",
    "lefthook": "^2.0.0",
    "tsx": "^4.20.6",
    "turbo": "^2.6.0",
    "typescript": "5.9.3",
    "ultracite": "5.6.4"
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
